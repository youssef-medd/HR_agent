# =============================================================================
# Welyne HR AI Agent — env vars (spec Appendix E)
# Copy to .env and fill. NEVER commit .env.
# =============================================================================

# ---- LLM providers (gateway fallback chain: Groq -> Gemini -> Mistral) ----
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Model routing (see DECISIONS.md D-001 — llama-3.3-70b-versatile deprecated 2026-06-17)
MODEL_JUDGE=openai/gpt-oss-120b
MODEL_EXTRACT=llama-3.1-8b-instant
MODEL_CHAT=openai/gpt-oss-120b

# ---- Database (app) ----
POSTGRES_USER=welyne
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=welyne_hr
DATABASE_URL=postgresql+psycopg://welyne:change_me_local_only@postgres:5432/welyne_hr

# ---- Redis (Celery broker + cache + Langfuse queue) ----
REDIS_AUTH=change_me_local_only
REDIS_URL=redis://:change_me_local_only@redis:6379/0

# ---- Langfuse self-host (spec §3) ----
# After first `docker compose up`, open http://localhost:3000, sign in with LANGFUSE_INIT_USER_*,
# open project "welyne-hr" -> Settings -> API Keys -> create -> paste below.
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse infra secrets (generate all 3 with: python -c "import secrets; print(secrets.token_hex(32))")
LANGFUSE_NEXTAUTH_SECRET=change_me_64_hex_chars
LANGFUSE_SALT=change_me_64_hex_chars
LANGFUSE_ENCRYPTION_KEY=change_me_64_hex_chars

# Langfuse first-boot admin user (auto-created on first boot)
LANGFUSE_INIT_USER_EMAIL=admin@welyne.local
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=change_me_at_least_8_chars

# ---- Clickhouse (Langfuse traces store) ----
CLICKHOUSE_PASSWORD=change_me_local_only

# ---- MinIO (Langfuse S3-compatible object store) ----
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_local_only_min_8_chars

# ---- App auth ----
JWT_SECRET=change_me_generate_with_python_secrets_token_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
PII_MASK_SALT=change_me_random_string

# ---- Email (dev = Gmail app password, prod = Resend/Brevo) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@welyne.local

# ---- WhatsApp (A5 pre-screening) ----
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ---- Interview scheduling ----
CALCOM_URL=
CALCOM_API_KEY=

# ---- IMAP (A3 email inbox polling) ----
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_POLL_SECONDS=120

# ---- App ----
APP_ENV=dev
LOG_LEVEL=INFO
